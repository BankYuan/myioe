# =============================================================================
# ioe 进销存 — 一键部署 .env 模板
# deploy.ps1 运行时会将 __SERVER_IP__ 替换为实际服务器 IP
# =============================================================================

# ---- 部署固定 ----
COMPOSE_PROJECT_NAME=ioe

# ---- Django 基本设置 ----
DEBUG=False
SECRET_KEY=p5k!d@v_z@6i*+j9x7b!n=o(h&w#q)s@l^m*g3r+t(u-v_y
ALLOWED_HOSTS=localhost,127.0.0.1,__SERVER_IP__

# ---- 数据库 (PostgreSQL) ----
DB_ENGINE=django.db.backends.postgresql
DB_NAME=inventory_db
DB_USER=db_user
DB_PASSWORD=db_password
DB_HOST=db
DB_PORT=5432

# ---- 第三方条码 API ----
BARCODE_API_KEY=your_barcode_api_key
ALI_BARCODE_APPCODE=your_ali_barcode_appcode

# ---- 对外只读 API (内容平台) ----
XHS_API_KEY=ioe-xhs-secret-CHANGE-ME

# ---- 邮件 ----
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@example.com

# ---- 静态/媒体 ----
STATIC_URL=/static/
MEDIA_URL=/media/

# ---- 日志 ----
LOG_LEVEL=INFO

# ---- 时区/语言 ----
TIME_ZONE=Asia/Shanghai
LANGUAGE_CODE=zh-hans

# ---- 备份 ----
BACKUP_ENABLED=True
BACKUP_INTERVAL_DAYS=7

# ---- MinIO 对象存储 (商品图片) ----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=ioe-media
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_DOMAIN=__SERVER_IP__:9002/ioe-media

# ---- Dify AI 后端 (进货单识别) ----
DIFY_BASE_URL=http://docker-nginx-1
DIFY_RECEIPT_API_KEY=app-YhW5Uf5xr5NNSvyfPYETfUCR
